[Unit]
Description=Caddy reverse proxy (internal TLS)
Wants=network-online.target
After=network-online.target apps-network.service
Requires=apps-network.service

[Service]
EnvironmentFile=%h/.config/apps-deployment/secrets/apps-secrets.env
Restart=always

[Container]
ContainerName=caddy
Image=docker.io/caddy:2.8
Network=apps
PublishPort=80:80/tcp
PublishPort=443:443/tcp
Volume=%h/.config/apps-deployment/config/caddy/Caddyfile:/etc/caddy/Caddyfile:ro,Z
Volume=%h/.local/share/apps-deployment/persist/caddy-data:/data:Z
Volume=%h/.local/share/apps-deployment/persist/caddy-state:/config:Z
Volume=%h/.local/share/apps-deployment/persist/www:/srv:ro,Z
Environment=DOMAIN=${DOMAIN}
Environment=CADDY_LOGLEVEL=${CADDY_LOGLEVEL}

[Install]
WantedBy=default.target
